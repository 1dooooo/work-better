{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FinalReport",
  "description": "workflow-agent 写入，用户读取",
  "type": "object",
  "required": ["task_id", "status", "timestamp"],
  "properties": {
    "task_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["done", "blocked", "escalated"],
      "description": "任务最终状态"
    },
    "test_summary": {
      "type": "object",
      "properties": {
        "total_tests_run": { "type": "integer" },
        "all_passed": { "type": "boolean" },
        "retry_count": { "type": "integer" },
        "gate_levels_executed": { "type": "array", "items": { "type": "string" } }
      }
    },
    "review_summary": {
      "type": "object",
      "properties": {
        "verdict": { "type": "string" },
        "findings_count": { "type": "integer" }
      }
    },
    "security_summary": {
      "type": "object",
      "properties": {
        "h_layer_passed": { "type": "boolean" },
        "vulnerabilities_found": { "type": "integer" },
        "security_tests_generated": { "type": "integer" }
      }
    },
    "uncovered_paths": {
      "type": "array",
      "items": { "type": "string" },
      "description": "最终仍未覆盖的变更路径"
    },
    "escalation_reason": {
      "type": ["string", "null"],
      "description": "上报原因（status=blocked 或 escalated 时）"
    },
    "metrics": {
      "type": ["object", "null"],
      "description": "workflow 执行指标，用于追踪效率和成本",
      "properties": {
        "total_duration_seconds": {
          "type": "integer",
          "description": "workflow 总耗时（秒）"
        },
        "agent_invocations": {
          "type": "object",
          "description": "各 agent 调用次数",
          "properties": {
            "dev_agent": { "type": "integer" },
            "test_agent": { "type": "integer" },
            "review_agent": { "type": "integer" },
            "product_reviewer": { "type": "integer" }
          }
        },
        "total_retries": {
          "type": "integer",
          "description": "总重试次数"
        },
        "retry_details": {
          "type": "array",
          "description": "每次重试的详情",
          "items": {
            "type": "object",
            "properties": {
              "retry_number": { "type": "integer" },
              "trigger": { "type": "string", "description": "触发重试的原因（test_fail / review_fail / product_fail）" },
              "source_location": { "type": "string", "description": "触发重试的代码位置" }
            }
          }
        }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
