{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chaos Test Report",
  "description": "Chaos Tester Agent 生成的混沌测试报告",
  "type": "object",
  "required": ["task_id", "timestamp", "overall_resilience", "fault_injections", "metrics"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "任务 ID"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "报告生成时间"
    },
    "overall_resilience": {
      "type": "string",
      "enum": ["resilient", "fragile", "critical"],
      "description": "整体韧性评估"
    },
    "fault_injections": {
      "type": "array",
      "description": "故障注入列表",
      "items": {
        "type": "object",
        "required": ["type", "target", "result"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["agent_failure", "communication_failure", "system_failure"],
            "description": "故障类型"
          },
          "target": {
            "type": "string",
            "description": "故障目标"
          },
          "result": {
            "type": "string",
            "enum": ["recovered", "degraded", "failed"],
            "description": "恢复结果"
          },
          "description": {
            "type": "string",
            "description": "故障描述"
          },
          "recovery_time_ms": {
            "type": "number",
            "description": "恢复时间（毫秒）"
          }
        }
      }
    },
    "weaknesses": {
      "type": "array",
      "description": "发现的弱点",
      "items": {
        "type": "object",
        "required": ["area", "severity", "description"],
        "properties": {
          "area": {
            "type": "string",
            "description": "弱点区域"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "严重程度"
          },
          "description": {
            "type": "string",
            "description": "弱点描述"
          },
          "suggestion": {
            "type": "string",
            "description": "改进建议"
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["total_injections", "recovered", "degraded", "failed"],
      "properties": {
        "total_injections": {
          "type": "integer",
          "description": "总故障注入数"
        },
        "recovered": {
          "type": "integer",
          "description": "成功恢复数"
        },
        "degraded": {
          "type": "integer",
          "description": "降级运行数"
        },
        "failed": {
          "type": "integer",
          "description": "失败数"
        },
        "average_recovery_time_ms": {
          "type": "number",
          "description": "平均恢复时间（毫秒）"
        }
      }
    }
  }
}
