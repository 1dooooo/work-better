{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "System Inspector Report",
  "description": "system-inspector 的输出：系统健康和执行效率监督报告",
  "type": "object",
  "required": ["task_id", "timestamp", "overall_health", "overall_status", "issues", "metrics"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "任务 ID"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "生成时间"
    },
    "overall_health": {
      "type": "string",
      "enum": ["healthy", "warning", "critical"],
      "description": "整体健康状况"
    },
    "overall_status": {
      "type": "string",
      "enum": ["success", "partial_success", "failure"],
      "description": "整体执行状态"
    },
    "issues": {
      "type": "array",
      "description": "发现的问题列表",
      "items": {
        "type": "object",
        "required": ["type", "severity", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["system", "agent", "execution", "efficiency"],
            "description": "问题类型"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "问题严重程度"
          },
          "description": { "type": "string", "description": "问题描述" },
          "affected_agent": { "type": "string", "description": "受影响的 Agent" },
          "suggestion": { "type": "string", "description": "建议的解决方案" }
        }
      }
    },
    "agent_executions": {
      "type": "array",
      "description": "各 Agent 执行情况",
      "items": {
        "type": "object",
        "required": ["agent", "status"],
        "properties": {
          "agent": { "type": "string", "description": "Agent 名称" },
          "status": {
            "type": "string",
            "enum": ["success", "failure", "timeout"],
            "description": "执行状态"
          },
          "duration_ms": { "type": "integer", "description": "执行时长（毫秒）" },
          "issues": {
            "type": "array",
            "items": { "type": "string" },
            "description": "执行中的问题"
          }
        }
      }
    },
    "optimization_suggestions": {
      "type": "array",
      "description": "优化建议",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["ordering", "parallelism", "retry", "prompt"],
            "description": "优化类型"
          },
          "description": { "type": "string", "description": "优化建议描述" },
          "expected_improvement": { "type": "string", "description": "预期改进" }
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "执行指标",
      "properties": {
        "total_agents": { "type": "integer", "description": "总 Agent 数" },
        "successful_agents": { "type": "integer", "description": "成功 Agent 数" },
        "failed_agents": { "type": "integer", "description": "失败 Agent 数" },
        "total_duration_ms": { "type": "integer", "description": "总执行时长（毫秒）" },
        "parallel_efficiency": { "type": "number", "description": "并行效率（0-1）" }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "建议列表"
    }
  }
}
