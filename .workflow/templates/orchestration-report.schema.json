{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Orchestration Report",
  "description": "Orchestrator Agent 生成的编排报告",
  "type": "object",
  "required": ["task_id", "timestamp", "overall_status", "agent_executions", "metrics"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "任务 ID"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "报告生成时间"
    },
    "overall_status": {
      "type": "string",
      "enum": ["success", "partial_success", "failure"],
      "description": "整体执行状态"
    },
    "agent_executions": {
      "type": "array",
      "description": "Agent 执行情况列表",
      "items": {
        "type": "object",
        "required": ["agent", "status"],
        "properties": {
          "agent": {
            "type": "string",
            "description": "Agent 名称"
          },
          "status": {
            "type": "string",
            "enum": ["success", "failure", "timeout"],
            "description": "执行状态"
          },
          "duration_ms": {
            "type": "number",
            "description": "执行时间（毫秒）"
          },
          "issues": {
            "type": "array",
            "description": "执行问题列表",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "description": "发现的问题列表",
      "items": {
        "type": "object",
        "required": ["type", "severity", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["execution", "efficiency", "collaboration"],
            "description": "问题类型"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "问题严重程度"
          },
          "description": {
            "type": "string",
            "description": "问题描述"
          },
          "affected_agent": {
            "type": "string",
            "description": "受影响的 Agent 名称"
          },
          "suggestion": {
            "type": "string",
            "description": "建议的解决方案"
          }
        }
      }
    },
    "optimization_suggestions": {
      "type": "array",
      "description": "优化建议列表",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["ordering", "parallelism", "retry"],
            "description": "优化类型"
          },
          "description": {
            "type": "string",
            "description": "优化建议"
          },
          "expected_improvement": {
            "type": "string",
            "description": "预期改进"
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["total_agents", "successful_agents", "failed_agents"],
      "properties": {
        "total_agents": {
          "type": "integer",
          "description": "总 Agent 数量"
        },
        "successful_agents": {
          "type": "integer",
          "description": "成功的 Agent 数量"
        },
        "failed_agents": {
          "type": "integer",
          "description": "失败的 Agent 数量"
        },
        "total_duration_ms": {
          "type": "number",
          "description": "总执行时间（毫秒）"
        },
        "parallel_efficiency": {
          "type": "number",
          "description": "并行效率（0-1）"
        }
      }
    }
  }
}
