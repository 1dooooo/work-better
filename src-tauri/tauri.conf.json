{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Work Better",
  "version": "0.1.0",
  "identifier": "com.work-better.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Work Better",
        "width": 960,
        "height": 680,
        "decorations": true,
        "resizable": true,
        "center": true
      },
      {
        "label": "capture",
        "title": "快速捕获",
        "width": 400,
        "height": 300,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "url": "index.html?view=capture"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns"]
  }
}
